# ── 数据库 ────────────────────────────────────────────
POSTGRES_DB=cdss
POSTGRES_USER=cdss
POSTGRES_PASSWORD=cdss123
DATABASE_URL=postgresql+asyncpg://cdss:cdss123@localhost:5432/cdss

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379/0

# ── Elasticsearch ─────────────────────────────────────
ES_URL=http://localhost:9200

# ── MinIO ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=cdss-files

# ── JWT ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── 外部系统对接模式（mock | real）────────────────────
HIS_MODE=mock
LIS_MODE=mock
PACS_MODE=mock
EMR_MODE=mock
ECG_MODE=mock
PATHOLOGY_MODE=mock

# ── 真实系统接口地址（HIS_MODE=real 时生效）────────────
HIS_API_URL=http://his.hospital.com/api
HIS_API_KEY=
LIS_API_URL=http://lis.hospital.com/api
LIS_API_KEY=
PACS_API_URL=http://pacs.hospital.com/api
EMR_API_URL=http://emr.hospital.com/api

# ── 应用环境 ──────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
